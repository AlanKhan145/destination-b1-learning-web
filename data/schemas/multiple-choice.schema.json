{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "multiple-choice.schema.json",
  "title": "Multiple choice question",
  "allOf": [
    { "$ref": "question-base.schema.json" },
    {
      "type": "object",
      "required": ["options", "correctOptionIds", "selectionMode"],
      "properties": {
        "type": { "const": "multiple-choice" },
        "options": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["id", "text"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "text": { "type": "string", "minLength": 1 }
            }
          }
        },
        "correctOptionIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "selectionMode": { "type": "string", "enum": ["single", "multiple"] },
        "shuffleOptions": { "type": "boolean", "default": true }
      }
    }
  ]
}
