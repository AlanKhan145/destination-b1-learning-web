{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "error-identification.schema.json",
  "title": "Error identification question",
  "allOf": [
    { "$ref": "question-base.schema.json" },
    {
      "type": "object",
      "required": ["segments", "correctSegmentIds"],
      "properties": {
        "type": { "const": "error-identification" },
        "segments": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["id", "text"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "text": { "type": "string", "minLength": 1 }
            }
          }
        },
        "correctSegmentIds": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "correction": { "type": ["string", "null"] }
      }
    }
  ]
}
