{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "secret-word-puzzle.schema.json",
  "title": "Secret word puzzle question",
  "description": "Solve N sub-clues; one letter from each (at revealIndex) combines to spell secretAnswer.",
  "allOf": [
    { "$ref": "question-base.schema.json" },
    {
      "type": "object",
      "required": ["words", "secretAnswer"],
      "properties": {
        "type": { "const": "secret-word-puzzle" },
        "words": {
          "type": "array",
          "minItems": 2,
          "items": {
            "type": "object",
            "required": ["clue", "answer", "letterCount", "revealIndex"],
            "properties": {
              "clue": { "type": "string", "minLength": 1 },
              "answer": { "type": "string", "minLength": 1 },
              "letterCount": { "type": "integer", "minimum": 1 },
              "revealIndex": {
                "type": "integer",
                "minimum": 1,
                "description": "1-based position within `answer` of the letter that contributes to secretAnswer."
              }
            }
          }
        },
        "secretAnswer": { "type": "string", "minLength": 1 }
      }
    }
  ]
}
