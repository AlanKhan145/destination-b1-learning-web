{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "short-answer.schema.json",
  "title": "Short answer question",
  "allOf": [
    { "$ref": "question-base.schema.json" },
    {
      "type": "object",
      "required": ["acceptedAnswers"],
      "properties": {
        "type": { "const": "short-answer" },
        "acceptedAnswers": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "answerValidation": {
          "type": "object",
          "properties": {
            "caseSensitive": { "type": "boolean", "default": false },
            "trimWhitespace": { "type": "boolean", "default": true },
            "collapseWhitespace": { "type": "boolean", "default": true },
            "ignoreEndingPunctuation": { "type": "boolean", "default": true },
            "matchMode": {
              "type": "string",
              "enum": ["exact", "normalized", "contains", "regex"],
              "default": "normalized"
            }
          }
        }
      }
    }
  ]
}
