        "enabled": true,
        "questionFilter": {
          "unitId": "unit-1",
          "topicIds": ["present-simple"],
          "status": ["published"]
        }
      },
      "description": "Used for present habits, permanent situations, states, and general truths.",
      "formula": null,
      "forms": {
        "columns": [
          "I / you / we / they",
          "He / she / it"
        ],
        "rows": [
          {
            "label": "Statement",
            "cells": [
              "I/You/We/They play ...",
              "He/She/It plays ..."
            ]
          },
          {
            "label": "Negative",
            "cells": [
              "I/You/We/They do not (don't) play ...",
              "He/She/It does not (doesn't) play ..."
            ]
          },
          {
            "label": "Question",
            "cells": [
              "Do I/you/we/they play ...?",
              "Does he/she/it play ...?"
            ]
          }
        ]
      },
      "uses": [
        {
          "usage": "Present habits",
          "example": "Marsha goes to dance lessons every Saturday."
        },
        {
          "usage": "Permanent situations",
          "example": "Does Dan work at the cinema?"
        },
        {
          "usage": "States",
          "example": "I like the new James Bond film."
        },
        {
          "usage": "General truths",
          "example": "You play chess with 32 pieces."
        }
      ],
      "notes": [
        {
          "type": "helpful-hint",
          "content": "The present simple is often used with the following words and phrases.",
          "examples": [
            "Adverbs: always, usually, often, sometimes, rarely, never",
            "Phrases: every Monday/week/etc",
            "Phrases: each Monday/week/etc",
            "Phrases: once/twice a week/month/etc",
            "Phrases: three times a week/month/etc"
          ],
          "highlightWords": [
            "always",
            "usually",
            "often",
            "sometimes",
            "rarely",
            "never",
            "every",
            "each",
            "once",
            "twice"
          ]
        },
        {
          "type": "helpful-hint",
          "content": "These adverbs usually go before the verb, but after the verb be.",
          "examples": [
            "I often play football with my friends.",
            "I am often late for my piano lessons."
          ],
          "highlightWords": [
            "often play",
            "am often"
          ]
        },
        {
          "type": "watch-out",
          "content": "The verbs be and have have irregular present forms. See page 182.",
          "examples": [],
          "highlightWords": [
            "be",
            "have"
          ]
        }
      ]
    },
    {
      "id": "present-continuous",
      "number": 2,
      "title": "Present continuous",
      "status": "available",
      "review": {
        "enabled": true,
        "questionFilter": {
          "unitId": "unit-1",
          "topicIds": ["present-continuous"],
          "status": ["published"]
        }
      },
      "description": "Used for actions happening now, temporary situations, and annoying habits.",
      "formula": "am/is/are + verb-ing",
      "forms": {
        "columns": [
          "I",
          "He / she / it",
          "You / we / they"
        ],
        "rows": [
          {
            "label": "Statement",
            "cells": [
              "I am ('m) playing ...",
              "He/She/It is ('s) playing ...",
              "You/We/They are ('re) playing ..."
            ]
          },
          {
            "label": "Negative",
            "cells": [
              "I am not ('m not) playing ...",
              "He/She/It is not (isn't / 's not) playing ...",
              "You/We/They are not (aren't / 're not) playing ..."
            ]
          },
          {
            "label": "Question",
            "cells": [
              "Am I playing ...?",
              "Is he/she/it playing ...?",
              "Are you/we/they playing ...?"
            ]
          }
        ]
      },
      "uses": [
        {
          "usage": "Actions happening now",
          "example": "Jan is watching a DVD upstairs."
        },
        {
          "usage": "Temporary situations",
          "example": "She is working at the museum until the end of the month."
        },
        {
          "usage": "Annoying habits, usually with always",
          "example": "My brother is always borrowing my CDs without asking!",
          "highlightWords": [
            "always"
          ]
        }
      ],
      "notes": [
        {
          "type": "helpful-hint",
          "content": "The present continuous is often used with the following words and phrases.",
          "examples": [
            "now",
            "right now",
            "at the moment",
            "today",
            "this week/month/etc"
          ],
          "highlightWords": [
            "now",
            "right now",
            "at the moment",
            "today",
            "this week",
            "this month"
          ]
        }
      ]
    },
    {
      "id": "stative-verbs",
      "number": 3,
      "title": "Stative verbs",
      "status": "available",
      "review": {
        "enabled": true,
        "questionFilter": {
          "unitId": "unit-1",
          "topicIds": ["stative-verbs"],
          "status": ["published"]
        }
      },
      "description": "Stative verbs describe states such as feelings and thoughts rather than actions.",
      "formula": null,
      "forms": {
        "columns": [],
        "rows": []
      },
      "uses": [
        {
          "usage": "Some common stative verbs",
          "example": "appear, be, believe, belong to, hate, have, include, know, like, love, need, prefer, see, seem, taste, think, understand, want"
        }
      ],
      "notes": [
        {
          "type": "rule",
          "content": "Stative verbs do not usually describe actions. They describe states such as feelings and thoughts. They are not normally used in continuous tenses.",
          "examples": [
            "Correct: I like reading books in my free time.",
            "Incorrect: I am liking reading books in my free time."
          ],
          "highlightWords": [
            "like",
            "am liking"
          ]
        },
        {
          "type": "watch-out",
          "content": "Some of these verbs, such as be, have and think, are used in continuous tenses when they describe actions.",
          "examples": [
            "What do you think about his new song?",
            "I'm thinking about last night's match."
          ],
          "highlightWords": [
            "be",
            "have",
            "think",
            "I'm thinking"
          ]
        }
      ]
    }
  ]
}